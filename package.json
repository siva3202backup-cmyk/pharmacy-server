{
  "name": "pharmacy-server",
  "version": "2.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node src/scripts/smoke-test.js",
    "db:schema": "psql \"$DATABASE_URL\" -f database/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f database/seed.sql",
    "db:seed:node": "node src/scripts/seed.js",
    "setup": "npm run db:schema && npm run db:seed:node"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
